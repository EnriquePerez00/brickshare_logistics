{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "start:dev-client": "expo start --dev-client",
    "start:go": "expo start --go",
    "ios": "expo run:ios",
    "ios:simulator": "expo run:ios --device \"iPhone 16 Pro\"",
    "ios:release": "expo run:ios --configuration Release",
    "android": "expo run:android",
    "android:device": "expo run:android --device",
    "android:release": "expo run:android --variant release",
    "prebuild": "expo prebuild",
    "prebuild:clean": "expo prebuild --clean",
    "prebuild:ios": "expo prebuild --platform ios --clean",
    "prebuild:android": "expo prebuild --platform android --clean",
    "build:ios:dev": "eas build --platform ios --profile development --local",
    "build:ios:preview": "eas build --platform ios --profile preview",
    "build:ios:prod": "eas build --platform ios --profile production",
    "build:android:dev": "eas build --platform android --profile development --local",
    "build:android:preview": "eas build --platform android --profile preview",
    "build:android:apk": "eas build --platform android --profile preview",
    "build:android:prod": "eas build --platform android --profile production",
    "build:all:preview": "eas build --platform all --profile preview",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf node_modules .expo ios android",
    "clean:install": "rm -rf node_modules && npm install",
    "clean:native": "rm -rf ios android && expo prebuild --clean",
    "doctor": "npx expo-doctor",
    "config": "expo config"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.1.34",
    "@react-navigation/native-stack": "^7.14.6",
    "@supabase/supabase-js": "^2.99.3",
    "expo": "^55.0.9",
    "expo-camera": "~55.0.10",
    "expo-constants": "~55.0.9",
    "expo-dev-client": "~55.0.19",
    "expo-device": "~55.0.10",
    "expo-document-picker": "~55.0.9",
    "expo-image-picker": "~55.0.14",
    "expo-location": "~55.1.4",
    "expo-status-bar": "~55.0.4",
    "jsqr": "^1.4.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.2",
    "react-native-webview": "13.16.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~5.9.2"
  },
  "private": true
}
