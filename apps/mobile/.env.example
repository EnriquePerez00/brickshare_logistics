# ============================================================
# Configuración de Supabase - Dual Database Architecture
# ============================================================

# ===== PRODUCCIÓN (DB2 - Brickshare Remota) =====
# Este es el servidor remoto con los datos maestros (usuarios, envíos, ubicaciones)
# Se usa para autenticación y lectura de datos de negocio
EXPO_PUBLIC_SUPABASE_URL=https://qumjzvhtotcvnzpjgjkl.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ===== LOCAL (DB1 - El Puente) =====
# Este es el servidor local donde se despliegan las Edge Functions
# Se usa para procesar escaneos y registrar auditoría en tiempo real
EXPO_PUBLIC_LOCAL_SUPABASE_URL=https://tu-proyecto-local.supabase.co
EXPO_PUBLIC_LOCAL_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ===== DESARROLLO (Opcional) =====
# Usar para testing locales
DEBUG_MODE=false
LOG_LEVEL=info